---
---

<section id="hero" class="relative min-h-screen min-h-[100dvh] flex flex-col overflow-x-hidden">
  <img src="/venue-hero.jpg" alt="La Fabrique des Ducs at night with illuminated pool" class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>

  <div class="relative z-10 flex-1 flex flex-col justify-center text-center px-4 sm:px-6 max-w-4xl mx-auto w-full pt-[calc(5.5rem+env(safe-area-inset-top,0px))] sm:pt-28 md:pt-32 pb-20 sm:pb-24">
    <p class="font-display italic text-gold-light text-base sm:text-lg md:text-xl mb-3 sm:mb-4 tracking-wide">You are invited to celebrate</p>
    <h1 class="font-display text-4xl sm:text-6xl lg:text-7xl font-bold text-white mb-4 leading-[1.1] tracking-tight">
      10 Years Together
    </h1>
    <div class="section-rule my-6 sm:my-8" aria-hidden="true"><span>§</span></div>
    <p class="text-cream/90 text-lg sm:text-xl mb-2">
      July 4 &ndash; 11, 2026
    </p>
    <p class="text-cream/70 text-base sm:text-lg mb-12">
      A week together in Burgundy, France
    </p>

    <div id="countdown" class="flex justify-center gap-6 sm:gap-10 mb-12">
      <div class="text-center">
        <span id="cd-days" class="block font-display text-3xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Days</span>
      </div>
      <div class="text-center">
        <span id="cd-hours" class="block font-display text-3xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Hours</span>
      </div>
      <div class="text-center">
        <span id="cd-mins" class="block font-display text-3xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Minutes</span>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-stretch justify-center gap-3 sm:gap-4 mx-auto w-full max-w-[min(100%,280px)] sm:max-w-none">
      <a
        href="#venue"
        class="inline-flex justify-center items-center box-border min-h-[48px] w-full sm:w-[280px] sm:min-w-[280px] rounded-full text-base font-medium tracking-normal bg-gold border-2 border-gold hover:bg-gold-dark hover:border-gold-dark text-white transition-colors px-5"
      >
        Discover the Week
      </a>
      <a
        href="https://docs.google.com/forms/d/e/1FAIpQLScSMKUpWXlexMgfIavlm9XgbkLAVlCeAGSx2-z355DoDqeU3Q/viewform"
        target="_blank"
        rel="noopener"
        class="inline-flex justify-center items-center box-border min-h-[48px] w-full sm:w-[280px] sm:min-w-[280px] rounded-full text-base font-medium tracking-normal border-2 border-cream/50 hover:border-cream hover:bg-white/10 text-white transition-all px-5"
      >
        Travel Form
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-cream/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
