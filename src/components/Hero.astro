---
---

<section id="hero" class="relative min-h-screen flex flex-col overflow-hidden">
  <img src="/venue-hero.jpg" alt="La Fabrique des Ducs at night with illuminated pool" class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>

  <div class="relative z-10 flex-1 flex flex-col justify-center text-center px-4 max-w-4xl mx-auto w-full pt-24 sm:pt-28 md:pt-32 pb-24">
    <p class="font-display italic text-gold-light text-lg sm:text-xl mb-4 tracking-wide">You are invited to celebrate</p>
    <h1 class="font-display text-5xl sm:text-7xl lg:text-8xl font-bold text-white mb-4 leading-tight">
      10 Years Together
    </h1>
    <p class="ornament text-gold/60 text-sm my-6">&mdash; &#10049; &mdash;</p>
    <p class="text-cream/90 text-lg sm:text-xl mb-2">
      July 4 &ndash; 11, 2026
    </p>
    <p class="text-cream/70 text-base sm:text-lg mb-12">
      A week together in Burgundy, France
    </p>

    <div id="countdown" class="flex justify-center gap-6 sm:gap-10 mb-12">
      <div class="text-center">
        <span id="cd-days" class="block font-display text-4xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Days</span>
      </div>
      <div class="text-center">
        <span id="cd-hours" class="block font-display text-4xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Hours</span>
      </div>
      <div class="text-center">
        <span id="cd-mins" class="block font-display text-4xl sm:text-5xl font-bold text-gold">--</span>
        <span class="text-cream/60 text-xs uppercase tracking-widest mt-1">Minutes</span>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4 max-w-md sm:max-w-none mx-auto">
      <a href="#venue" class="inline-flex justify-center items-center bg-gold hover:bg-gold-dark text-white font-medium px-8 py-3 rounded-full transition-colors text-sm uppercase tracking-wider w-full sm:w-56">
        Discover the Week
      </a>
      <a href="https://docs.google.com/forms/d/e/1FAIpQLScSMKUpWXlexMgfIavlm9XgbkLAVlCeAGSx2-z355DoDqeU3Q/viewform" target="_blank" rel="noopener" class="inline-flex justify-center items-center border-2 border-cream/50 hover:border-cream hover:bg-white/10 text-white font-medium px-8 py-3 rounded-full transition-all text-sm uppercase tracking-wider w-full sm:w-56">
        Travel Form
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-cream/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
